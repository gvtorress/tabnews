{
  "name": "tabnews",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/gvtorress/tabnews#readme",
  "bugs": {
    "url": "https://github.com/gvtorress/tabnews/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gvtorress/tabnews.git"
  },
  "license": "MIT",
  "author": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run services:wait:database && npm run migrations:up && next dev",
    "test": "npm run services:up && concurrently --names next,jest --hide next -k -s command-jest  \"next dev\" \"jest --runInBand --verbose\"",
    "posttest": "npm run services:stop",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate --migrations-dir infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "lint:prettier:check": "prettier --check tests/integration/api/v1/migrations/post.test.js",
    "lint:prettier:fix": "prettier --write tests/integration/api/v1/migrations/post.test.js",
    "lint:eslint:check": "next lint --dir .",
    "prepare": "husky",
    "commit": "cz"
  },
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "17.3.1",
    "dotenv-expand": "12.0.3",
    "next": "^14.2.5",
    "node-pg-migrate": "^7.6.1",
    "pg": "8.11.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.1",
    "husky": "9.1.7",
    "jest": "29.7",
    "prettier": "3.8.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
